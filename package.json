// ── package.json ──────────────────────────────────────────────────────────────
{
  "name": "ktownpitque-autoposter",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "canvas": "^2.11.2",
    "express": "^4.19.2",
    "form-data": "^4.0.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2"
  }
}

// ── .env.example ──────────────────────────────────────────────────────────────
// Copy this to .env and fill in your values (never commit .env to git)

ANTHROPIC_API_KEY=sk-ant-...
FB_PAGE_ID=123456789012345
FB_ACCESS_TOKEN=EAABs...your-long-lived-token...
IG_ACCOUNT_ID=17841400000000000
PUBLIC_URL=https://your-app-name.railway.app
CRON_SCHEDULE=0 11 * * 2,4,6
PORT=3000

// ── CRON SCHEDULE CHEATSHEET ──────────────────────────────────────────────────
// "0 11 * * 2,4,6"    = 11:00am Tue, Thu, Sat  ← default
// "0 12 * * 1,3,5"    = 12:00pm Mon, Wed, Fri
// "0 9,17 * * 2,4,6"  = 9am AND 5pm Tue, Thu, Sat (2x per day)
// "0 11 * * *"         = 11am every day

// ── DEPLOY TO RAILWAY (free tier works) ──────────────────────────────────────
// 1. Go to railway.app → New Project → Deploy from GitHub
// 2. Connect your GitHub repo containing server.js + package.json
// 3. Add your logo: Settings → Variables → upload logo.png OR include in repo
// 4. Set environment variables (copy from .env.example above):
//    ANTHROPIC_API_KEY, FB_PAGE_ID, FB_ACCESS_TOKEN, IG_ACCOUNT_ID, PUBLIC_URL
// 5. Railway auto-detects Node and runs `npm start`
// 6. Done — it posts on your cron schedule forever, zero babysitting.

// ── MANUAL TRIGGER (test without waiting for cron) ───────────────────────────
// POST https://your-app.railway.app/post
// Body: {}                        ← auto-picks next theme in rotation
// Body: {"themeId": "weekend"}    ← force a specific theme

// ── VIEW POST LOG ─────────────────────────────────────────────────────────────
// GET https://your-app.railway.app/log   ← last 100 posts with FB/IG IDs

// ── THEMES AVAILABLE ─────────────────────────────────────────────────────────
// weekend, menu, behind, hype, quote, countdown, community
